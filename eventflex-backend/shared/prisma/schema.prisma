// This is your Prisma schema file for EventFlex
// Learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../../node_modules/.prisma/client"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ────────────────────────────────────────────
// ENUMS
// ────────────────────────────────────────────

enum UserRole {
  STUDENT
  ORGANIZER
  ADMIN
  SUPER_ADMIN
}

enum OAuthProvider {
  GOOGLE
  GITHUB
}

enum EventCategory {
  HACKATHON
  TECH_FEST
  WORKSHOP
  WEBINAR
  MEETUP
  CONFERENCE
}

enum EventType {
  ONLINE
  OFFLINE
  HYBRID
}

enum EventStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  PUBLISHED
  ONGOING
  COMPLETED
  CANCELLED
}

enum EventVisibility {
  PUBLIC
  PRIVATE
  UNLISTED
}

enum OrganizerRole {
  PRIMARY_ORGANIZER
  CO_ORGANIZER
  MODERATOR
}

enum TicketVisibility {
  PUBLIC
  HIDDEN
  MEMBERS_ONLY
}

enum RegistrationStatus {
  PENDING
  CONFIRMED
  CHECKED_IN
  CANCELLED
  REFUNDED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum PaymentMethod {
  CARD
  UPI
  WALLET
}

enum TeamMemberRole {
  LEADER
  MEMBER
}

enum MessageType {
  TEXT
  IMAGE
  FILE
}

enum DiscountType {
  PERCENTAGE
  FIXED_AMOUNT
}

enum PaymentRecordStatus {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
}

enum RefundStatus {
  PENDING
  SUCCEEDED
  FAILED
}

enum NotificationType {
  REGISTRATION_CONFIRMED
  EVENT_REMINDER
  TEAM_INVITE
  PAYMENT_SUCCESS
  EVENT_UPDATE
  CERTIFICATE_READY
  WAITLIST_SPOT_AVAILABLE
  TEAM_MESSAGE
  SYSTEM
}

enum FeedbackType {
  CONTENT
  ORGANIZATION
  VENUE
  OVERALL
}

enum AdminActionType {
  APPROVE_EVENT
  REJECT_EVENT
  SUSPEND_USER
  ACTIVATE_USER
  DELETE_EVENT
  FEATURE_EVENT
  UNFEATURE_EVENT
}

enum AdminTargetType {
  USER
  EVENT
  REGISTRATION
}

enum NotificationFrequency {
  REALTIME
  DAILY_DIGEST
  WEEKLY_DIGEST
}

enum Theme {
  LIGHT
  DARK
  AUTO
}

// ────────────────────────────────────────────
// MODELS
// ────────────────────────────────────────────

model User {
  id               String   @id @default(uuid())
  email            String   @unique
  passwordHash     String?  @map("password_hash")
  username         String   @unique
  fullName         String   @map("full_name")
  avatarUrl        String?  @map("avatar_url")
  role             UserRole @default(STUDENT)
  collegeName      String?  @map("college_name")
  graduationYear   Int?     @map("graduation_year")
  department       String?
  skills           String[] @default([])
  interests        String[] @default([])
  emailVerified    Boolean  @default(false) @map("email_verified")
  phoneNumber      String?  @map("phone_number")
  isActive         Boolean  @default(true) @map("is_active")
  lastLogin        DateTime? @map("last_login")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  // Relations
  oauthProviders          OAuthProviderRecord[]
  preferences             UserPreferences?
  eventsCreated           Event[]
  eventOrganizers         EventOrganizer[]
  registrations           Registration[]
  teamLeaderOf            Team[]
  teamMemberships         TeamMember[]
  teamMessages            TeamChatMessage[]
  notifications           Notification[]
  savedEvents             SavedEvent[]
  waitlistEntries         Waitlist[]
  certificates            Certificate[]
  feedback                EventFeedback[]
  promoCodes              PromoCode[]
  adminActions            AdminAction[]
  emailVerificationTokens EmailVerificationToken[]
  passwordResetTokens     PasswordResetToken[]

  @@index([email])
  @@index([username])
  @@index([role])
  @@map("users")
}

model OAuthProviderRecord {
  id             String        @id @default(uuid())
  userId         String        @map("user_id")
  provider       OAuthProvider
  providerUserId String        @map("provider_user_id")
  accessToken    String?       @map("access_token")
  refreshToken   String?       @map("refresh_token")
  createdAt      DateTime      @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerUserId])
  @@index([userId])
  @@map("oauth_providers")
}

model UserPreferences {
  id                    String                @id @default(uuid())
  userId                String                @unique @map("user_id")
  emailNotifications    Boolean               @default(true) @map("email_notifications")
  smsNotifications      Boolean               @default(false) @map("sms_notifications")
  pushNotifications     Boolean               @default(true) @map("push_notifications")
  newsletter            Boolean               @default(true)
  notificationFrequency NotificationFrequency @default(REALTIME) @map("notification_frequency")
  theme                 Theme                 @default(DARK)
  updatedAt             DateTime              @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_preferences")
}

model Event {
  id                    String          @id @default(uuid())
  title                 String
  slug                  String          @unique
  description           String          @db.Text
  shortDescription      String?         @map("short_description")
  category              EventCategory
  bannerUrl             String?         @map("banner_url")
  eventType             EventType       @default(ONLINE) @map("event_type")
  venueName             String?         @map("venue_name")
  venueAddress          String?         @map("venue_address")
  venueCity             String?         @map("venue_city")
  venueState            String?         @map("venue_state")
  venueCountry          String?         @map("venue_country")
  startDate             DateTime        @map("start_date")
  endDate               DateTime        @map("end_date")
  registrationStartDate DateTime        @map("registration_start_date")
  registrationEndDate   DateTime        @map("registration_end_date")
  maxParticipants       Int?            @map("max_participants")
  maxTeamSize           Int             @default(1) @map("max_team_size")
  minTeamSize           Int             @default(1) @map("min_team_size")
  allowSoloParticipation Boolean        @default(true) @map("allow_solo_participation")
  status                EventStatus     @default(DRAFT)
  visibility            EventVisibility @default(PUBLIC)
  tags                  String[]        @default([])
  requirements          Json?
  prizes                Json?           // JSONB array
  schedule              Json?           // JSONB array
  faq                   Json?           // JSONB array
  rules                 String?         @db.Text
  isFeatured            Boolean         @default(false) @map("is_featured")
  isRecurring           Boolean         @default(false) @map("is_recurring")
  recurrencePattern     Json?           @map("recurrence_pattern")
  createdBy             String          @map("created_by")
  viewCount             Int             @default(0) @map("view_count")
  createdAt             DateTime        @default(now()) @map("created_at")
  updatedAt             DateTime        @updatedAt @map("updated_at")

  // Relations
  creator        User             @relation(fields: [createdBy], references: [id])
  organizers     EventOrganizer[]
  ticketTypes    TicketType[]
  registrations  Registration[]
  teams          Team[]
  promoCodes     PromoCode[]
  savedBy        SavedEvent[]
  waitlist       Waitlist[]
  certificates   Certificate[]
  feedback       EventFeedback[]
  analytics      AnalyticsEvent[]

  @@index([slug])
  @@index([status])
  @@index([category])
  @@index([createdBy])
  @@index([isFeatured])
  @@index([startDate])
  @@index([venueCity])
  @@map("events")
}

model EventOrganizer {
  id          String        @id @default(uuid())
  eventId     String        @map("event_id")
  userId      String        @map("user_id")
  role        OrganizerRole @default(CO_ORGANIZER)
  permissions Json?         // JSONB array of permission strings
  addedAt     DateTime      @default(now()) @map("added_at")

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
  @@index([eventId])
  @@index([userId])
  @@map("event_organizers")
}

model TicketType {
  id            String           @id @default(uuid())
  eventId       String           @map("event_id")
  name          String
  description   String?
  price         Decimal          @db.Decimal(10, 2)
  currency      String           @default("USD")
  quantityTotal Int              @map("quantity_total")
  quantitySold  Int              @default(0) @map("quantity_sold")
  saleStartDate DateTime         @map("sale_start_date")
  saleEndDate   DateTime         @map("sale_end_date")
  isActive      Boolean          @default(true) @map("is_active")
  visibility    TicketVisibility @default(PUBLIC)
  createdAt     DateTime         @default(now()) @map("created_at")
  updatedAt     DateTime         @updatedAt @map("updated_at")

  event         Event          @relation(fields: [eventId], references: [id], onDelete: Cascade)
  registrations Registration[]

  @@index([eventId])
  @@map("ticket_types")
}

model Registration {
  id                 String             @id @default(uuid())
  eventId            String             @map("event_id")
  userId             String             @map("user_id")
  ticketTypeId       String             @map("ticket_type_id")
  teamId             String?            @map("team_id")
  registrationNumber String             @unique @map("registration_number")
  status             RegistrationStatus @default(PENDING)
  paymentStatus      PaymentStatus      @default(PENDING) @map("payment_status")
  paymentId          String?            @map("payment_id")
  amountPaid         Decimal            @default(0) @db.Decimal(10, 2) @map("amount_paid")
  currency           String             @default("USD")
  promoCodeId        String?            @map("promo_code_id")
  discountAmount     Decimal            @default(0) @db.Decimal(10, 2) @map("discount_amount")
  qrCodeUrl          String?            @map("qr_code_url")
  checkedInAt        DateTime?          @map("checked_in_at")
  cancelledAt        DateTime?          @map("cancelled_at")
  cancellationReason String?            @db.Text @map("cancellation_reason")
  additionalInfo     Json?              @map("additional_info")
  createdAt          DateTime           @default(now()) @map("created_at")
  updatedAt          DateTime           @updatedAt @map("updated_at")

  event       Event       @relation(fields: [eventId], references: [id])
  user        User        @relation(fields: [userId], references: [id])
  ticketType  TicketType  @relation(fields: [ticketTypeId], references: [id])
  team        Team?       @relation(fields: [teamId], references: [id])
  promoCode   PromoCode?  @relation(fields: [promoCodeId], references: [id])
  payments    Payment[]
  certificate Certificate?

  @@index([eventId])
  @@index([userId])
  @@index([status])
  @@index([registrationNumber])
  @@map("registrations")
}

model Team {
  id                String   @id @default(uuid())
  eventId           String   @map("event_id")
  name              String
  teamCode          String   @unique @map("team_code")
  leaderId          String   @map("leader_id")
  maxMembers        Int      @map("max_members")
  currentMemberCount Int     @default(1) @map("current_member_count")
  inviteToken       String   @unique @map("invite_token")
  inviteExpiresAt   DateTime @map("invite_expires_at")
  isLocked          Boolean  @default(false) @map("is_locked")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  event         Event             @relation(fields: [eventId], references: [id], onDelete: Cascade)
  leader        User              @relation(fields: [leaderId], references: [id])
  members       TeamMember[]
  chatMessages  TeamChatMessage[]
  registrations Registration[]

  @@index([eventId])
  @@index([leaderId])
  @@index([inviteToken])
  @@map("teams")
}

model TeamMember {
  id         String         @id @default(uuid())
  teamId     String         @map("team_id")
  userId     String         @map("user_id")
  role       TeamMemberRole @default(MEMBER)
  joinedAt   DateTime       @default(now()) @map("joined_at")
  invitedBy  String?        @map("invited_by")

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@index([teamId])
  @@index([userId])
  @@map("team_members")
}

model TeamChatMessage {
  id          String      @id @default(uuid())
  teamId      String      @map("team_id")
  senderId    String      @map("sender_id")
  message     String      @db.Text
  messageType MessageType @default(TEXT) @map("message_type")
  fileUrl     String?     @map("file_url")
  isEdited    Boolean     @default(false) @map("is_edited")
  isDeleted   Boolean     @default(false) @map("is_deleted")
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  team   Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  sender User @relation(fields: [senderId], references: [id])

  @@index([teamId])
  @@index([senderId])
  @@index([createdAt])
  @@map("team_chat_messages")
}

model PromoCode {
  id                String       @id @default(uuid())
  eventId           String?      @map("event_id") // null = platform-wide
  code              String       @unique
  description       String?
  discountType      DiscountType @map("discount_type")
  discountValue     Decimal      @db.Decimal(10, 2) @map("discount_value")
  maxUses           Int?         @map("max_uses")
  currentUses       Int          @default(0) @map("current_uses")
  minPurchaseAmount Decimal?     @db.Decimal(10, 2) @map("min_purchase_amount")
  validFrom         DateTime     @map("valid_from")
  validUntil        DateTime     @map("valid_until")
  isActive          Boolean      @default(true) @map("is_active")
  createdBy         String       @map("created_by")
  createdAt         DateTime     @default(now()) @map("created_at")

  event         Event?         @relation(fields: [eventId], references: [id], onDelete: Cascade)
  creator       User           @relation(fields: [createdBy], references: [id])
  registrations Registration[]

  @@index([code])
  @@index([eventId])
  @@map("promo_codes")
}

model Payment {
  id                    String              @id @default(uuid())
  registrationId        String              @map("registration_id")
  stripePaymentIntentId String              @unique @map("stripe_payment_intent_id")
  stripeChargeId        String?             @map("stripe_charge_id")
  amount                Decimal             @db.Decimal(10, 2)
  currency              String              @default("USD")
  status                PaymentRecordStatus @default(PENDING)
  paymentMethod         PaymentMethod?      @map("payment_method")
  failureReason         String?             @db.Text @map("failure_reason")
  refundAmount          Decimal?            @db.Decimal(10, 2) @map("refund_amount")
  refundedAt            DateTime?           @map("refunded_at")
  metadata              Json?
  createdAt             DateTime            @default(now()) @map("created_at")
  updatedAt             DateTime            @updatedAt @map("updated_at")

  registration Registration @relation(fields: [registrationId], references: [id])
  refunds      Refund[]

  @@index([registrationId])
  @@index([stripePaymentIntentId])
  @@index([status])
  @@map("payments")
}

model Refund {
  id             String       @id @default(uuid())
  paymentId      String       @map("payment_id")
  registrationId String       @map("registration_id")
  stripeRefundId String       @unique @map("stripe_refund_id")
  amount         Decimal      @db.Decimal(10, 2)
  reason         String       @db.Text
  status         RefundStatus @default(PENDING)
  processedAt    DateTime?    @map("processed_at")
  createdAt      DateTime     @default(now()) @map("created_at")

  payment Payment @relation(fields: [paymentId], references: [id])

  @@index([paymentId])
  @@index([registrationId])
  @@map("refunds")
}

model SavedEvent {
  id      String   @id @default(uuid())
  userId  String   @map("user_id")
  eventId String   @map("event_id")
  savedAt DateTime @default(now()) @map("saved_at")

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([userId, eventId])
  @@index([userId])
  @@map("saved_events")
}

model Notification {
  id        String           @id @default(uuid())
  userId    String           @map("user_id")
  type      NotificationType
  title     String
  message   String           @db.Text
  actionUrl String?          @map("action_url")
  isRead    Boolean          @default(false) @map("is_read")
  metadata  Json?
  createdAt DateTime         @default(now()) @map("created_at")
  readAt    DateTime?        @map("read_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
  @@map("notifications")
}

model Certificate {
  id             String   @id @default(uuid())
  registrationId String   @unique @map("registration_id")
  eventId        String   @map("event_id")
  userId         String   @map("user_id")
  certificateUrl String   @map("certificate_url")
  certificateId  String   @unique @map("certificate_id")
  issuedAt       DateTime @map("issued_at")
  createdAt      DateTime @default(now()) @map("created_at")

  registration Registration @relation(fields: [registrationId], references: [id])
  event        Event        @relation(fields: [eventId], references: [id])
  user         User         @relation(fields: [userId], references: [id])

  @@index([eventId])
  @@index([userId])
  @@index([certificateId])
  @@map("certificates")
}

model EventFeedback {
  id                String       @id @default(uuid())
  eventId           String       @map("event_id")
  userId            String       @map("user_id")
  rating            Int          // 1-5
  review            String?      @db.Text
  feedbackType      FeedbackType @map("feedback_type")
  isVerifiedAttendee Boolean     @default(false) @map("is_verified_attendee")
  isAnonymous       Boolean      @default(false) @map("is_anonymous")
  createdAt         DateTime     @default(now()) @map("created_at")
  updatedAt         DateTime     @updatedAt @map("updated_at")

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
  @@index([eventId])
  @@map("event_feedback")
}

model Waitlist {
  id          String    @id @default(uuid())
  eventId     String    @map("event_id")
  userId      String    @map("user_id")
  position    Int
  notified    Boolean   @default(false)
  joinedAt    DateTime  @default(now()) @map("joined_at")
  convertedAt DateTime? @map("converted_at")

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
  @@index([eventId])
  @@map("waitlist")
}

model EmailVerificationToken {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
  @@map("email_verification_tokens")
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  used      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@map("password_reset_tokens")
}

model AnalyticsEvent {
  id                String   @id @default(uuid())
  eventId           String   @map("event_id")
  date              DateTime @db.Date
  registrationsCount Int     @default(0) @map("registrations_count")
  cancellationsCount Int     @default(0) @map("cancellations_count")
  revenue           Decimal  @default(0) @db.Decimal(12, 2)
  viewsCount        Int      @default(0) @map("views_count")
  uniqueVisitors    Int      @default(0) @map("unique_visitors")
  conversionRate    Decimal  @default(0) @db.Decimal(5, 4) @map("conversion_rate")
  createdAt         DateTime @default(now()) @map("created_at")

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([eventId, date])
  @@index([eventId])
  @@index([date])
  @@map("analytics_events")
}

model AdminAction {
  id         String          @id @default(uuid())
  adminId    String          @map("admin_id")
  actionType AdminActionType @map("action_type")
  targetType AdminTargetType @map("target_type")
  targetId   String          @map("target_id")
  reason     String?         @db.Text
  metadata   Json?
  createdAt  DateTime        @default(now()) @map("created_at")

  admin User @relation(fields: [adminId], references: [id])

  @@index([adminId])
  @@index([targetId])
  @@index([actionType])
  @@map("admin_actions")
}
