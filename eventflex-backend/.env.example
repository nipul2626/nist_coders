# ================================================
# EventFlex Backend - Environment Variables
# ================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ── Node Environment ──────────────────────────────
NODE_ENV=development                         # development | staging | production
PORT=3001                                    # API service port
WS_PORT=3002                                 # WebSocket service port
WORKER_PORT=3003                             # Worker service port

# ── Database (PostgreSQL) ──────────────────────────
DATABASE_URL="postgresql://eventflex:password@localhost:5432/eventflex_db?schema=public"
# For production (connection pooling via PgBouncer):
# DATABASE_URL="postgresql://eventflex:password@db.host:6543/eventflex_db?schema=public&pgbouncer=true"
DIRECT_URL="postgresql://eventflex:password@localhost:5432/eventflex_db?schema=public"

# ── Redis ─────────────────────────────────────────
REDIS_URL="redis://localhost:6379"
# For Upstash Redis: redis://:password@host:port
REDIS_SESSION_TTL=604800                     # 7 days in seconds (refresh token TTL)

# ── JWT Secrets ────────────────────────────────────
JWT_ACCESS_SECRET=your-super-secret-access-key-change-this-in-production-min-32-chars
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-this-in-production-min-32-chars
JWT_ACCESS_EXPIRES_IN=15m                    # Access token expiry
JWT_REFRESH_EXPIRES_IN=7d                    # Refresh token expiry

# ── OAuth - Google ─────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3001/api/v1/auth/google/callback

# ── OAuth - GitHub ─────────────────────────────────
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GITHUB_CALLBACK_URL=http://localhost:3001/api/v1/auth/github/callback

# ── Frontend URL ───────────────────────────────────
FRONTEND_URL=http://localhost:3000            # Next.js frontend URL
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ── AWS S3 ─────────────────────────────────────────
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=ap-south-1
AWS_S3_BUCKET_NAME=eventflex-assets
AWS_S3_URL=https://eventflex-assets.s3.ap-south-1.amazonaws.com
# Optionally use CloudFront CDN for S3 files:
AWS_CLOUDFRONT_URL=https://your-distribution.cloudfront.net

# ── Stripe ─────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key
STRIPE_WEBHOOK_SECRET=whsec_your-stripe-webhook-secret
# Use sk_live_* and pk_live_* for production

# ── SendGrid ───────────────────────────────────────
SENDGRID_API_KEY=SG.your-sendgrid-api-key
SENDGRID_FROM_EMAIL=noreply@eventflex.com
SENDGRID_FROM_NAME=EventFlex

# SendGrid Dynamic Template IDs (create these in SendGrid dashboard)
SENDGRID_TEMPLATE_WELCOME=d-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SENDGRID_TEMPLATE_VERIFY_EMAIL=d-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SENDGRID_TEMPLATE_RESET_PASSWORD=d-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SENDGRID_TEMPLATE_REGISTRATION_CONFIRMED=d-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SENDGRID_TEMPLATE_EVENT_REMINDER=d-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SENDGRID_TEMPLATE_TEAM_INVITE=d-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SENDGRID_TEMPLATE_PAYMENT_RECEIPT=d-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SENDGRID_TEMPLATE_REFUND_CONFIRMED=d-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SENDGRID_TEMPLATE_CERTIFICATE_READY=d-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SENDGRID_TEMPLATE_EVENT_UPDATE=d-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SENDGRID_TEMPLATE_WAITLIST_AVAILABLE=d-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── OpenAI ─────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4-turbo-preview             # or gpt-4o

# ── AI Service ─────────────────────────────────────
AI_SERVICE_URL=http://localhost:8000          # Python FastAPI service URL
AI_SERVICE_SECRET=internal-ai-service-secret  # Internal auth between services

# ── Error Tracking (Sentry) ────────────────────────
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project
# Set SENTRY_DSN="" to disable Sentry

# ── App Config ─────────────────────────────────────
APP_URL=https://api.eventflex.com
APP_NAME=EventFlex
MAX_FILE_SIZE_MB=5                           # Max image upload size in MB
MAX_DOC_SIZE_MB=10                           # Max document upload size in MB

# ── Rate Limiting ──────────────────────────────────
RATE_LIMIT_AUTH_MAX=5                        # Max auth requests per window
RATE_LIMIT_AUTH_WINDOW_MS=900000             # 15 minutes in ms
RATE_LIMIT_API_MAX=100                       # General API limit
RATE_LIMIT_API_WINDOW_MS=900000
RATE_LIMIT_PAYMENT_MAX=10                    # Payment creation limit
RATE_LIMIT_PAYMENT_WINDOW_MS=3600000         # 1 hour in ms
RATE_LIMIT_AI_MAX=20                         # AI endpoint limit
RATE_LIMIT_AI_WINDOW_MS=3600000

# ── Encryption ─────────────────────────────────────
ENCRYPTION_KEY=your-32-char-encryption-key!!  # Exactly 32 chars for AES-256

# ── Bull Queue ─────────────────────────────────────
BULL_REDIS_URL="redis://localhost:6379"      # Can be same Redis or separate

# ── Logging ────────────────────────────────────────
LOG_LEVEL=info                               # error | warn | info | debug
LOG_FORMAT=json                              # json | simple (use simple for dev)

# ── Crypto Salt ────────────────────────────────────
BCRYPT_SALT_ROUNDS=12

# ── Email Verification ─────────────────────────────
EMAIL_VERIFICATION_EXPIRES_HOURS=24
PASSWORD_RESET_EXPIRES_HOURS=1

# ── Event Config ───────────────────────────────────
DEFAULT_EVENT_CURRENCY=USD
MAX_TEAM_CHAT_MESSAGE_LENGTH=2000
MAX_REGISTRATION_EXPORT_ROWS=10000

# ── Certificate ────────────────────────────────────
CERTIFICATE_TEMPLATE_PATH=./templates/certificate.html
